                    ],
                },
                Argument {
                    name: [
                        Text(
                            "ulnast",
                        ),
                    ],
                    description: [
                        Text(
                            "Numeric vector of upper limit of normal AST values (IU/L).",
                        ),
                        NewLine,
                        Text(
                            "Typically 33 IU/L for most laboratories",
                        ),
                    ],
                },
                Argument {
                    name: [
                        Text(
                            "bili",
                        ),
                    ],
                    description: [
                        Text(
                            "Numeric vector of total bilirubin concentrations (mg/dL)",
                        ),
                    ],
                },
                Argument {
                    name: [
                        Text(
                            "ulnbili",
                        ),
                    ],
                    description: [
                        Text(
                            "Numeric vector of upper limit of normal bilirubin values (mg/dL).",
                        ),
                        NewLine,
                        Text(
                            "Typically 1.2 mg/dL for most laboratories",
                        ),
                    ],
                },
            ],
        ),
        NewLine,
        Section {
            title: [
                Text(
                    "Value",
                ),
            ],
            children: [
                NewLine,
                Text(
                    "Integer vector of hepatic function categories (1-4). Returns the value of",
                ),
                NewLine,
                Command {
                    name: "code",
                    options: None,
                    args: [
                        [
                            Text(
                                "getOption(\"scicalc.missing_value\")",
                            ),
                        ],
                    ],
                },
                Text(
                    " (default ",
                ),
                Command {
                    name: "code",
                    options: None,
                    args: [
                        [
                            Text(
                                "-999",
                            ),
                        ],
                    ],
                },
                Text(
                    ") for",
                ),
                NewLine,
                Text(
                    "missing values.",
                ),
                NewLine,
            ],
        },
        NewLine,
        Section {
            title: [
                Text(
                    "Description",
                ),
            ],
            children: [
                NewLine,
                Text(
                    "This function categorizes hepatic function impairment using the National Cancer Institute",
                ),
                NewLine,
                Text(
                    "Organ Dysfunction Working Group (NCI-ODWG) criteria. It evaluates aspartate aminotransferase",
                ),
                NewLine,
                Text(
                    "(AST) and bilirubin levels relative to their upper limits of normal to determine hepatic",
                ),
                NewLine,
                Text(
                    "impairment severity. The function handles edge cases where bilirubin values are very close",
                ),
                NewLine,
                Text(
                    "to category boundaries using floating-point tolerant comparisons.",
                ),
                NewLine,
            ],
        },
        NewLine,
        Section {
            title: [
                Text(
                    "Details",
                ),
            ],
            children: [
                NewLine,
                Command {
                    name: "strong",
                    options: None,
                    args: [
                        [
                            Text(
                                "The NCI-ODWG hepatic function categories are defined as",
                            ),
                        ],
                    ],
                },
                Text(
                    ":",
                ),
                NewLine,
                List {
                    kind: Itemize,
                    items: [
                        ListItem {
                            term: None,
                            children: [
                                Text(
                                    " 1: Normal: AST ≤ ULN AND bilirubin ≤ ULN",
                                ),
                                NewLine,
                            ],
                        },
                        ListItem {
                            term: None,
                            children: [
                                Text(
                                    " 2: Mild impairment: AST > ULN OR bilirubin > ULN but ≤ 1.5 × ULN",
                                ),
                                NewLine,
                            ],
                        },
                        ListItem {
                            term: None,
                            children: [
                                Text(
                                    " 3: Moderate impairment: Bilirubin > 1.5 × ULN but ≤ 3 × ULN",
                                ),
                                NewLine,
                            ],
                        },
                        ListItem {
                            term: None,
                            children: [
                                Text(
                                    " 4: Severe impairment: Bilirubin > 3 × ULN",
                                ),
                                NewLine,
                            ],
                        },
                    ],
                },
                NewLine,
                NewLine,
                Command {
                    name: "strong",
                    options: None,
                    args: [
                        [
                            Text(
                                "Special handling:",
                            ),
                        ],
                    ],
                },
                NewLine,
                Text(
                    "The function uses ",
                ),
                Command {
                    name: "code",
                    options: None,
                    args: [
                        [
                            Text(
                                "dplyr::near()",
                            ),
                        ],
                    ],
                },
                Text(
                    " for boundary comparisons when bilirubin",
                ),
                NewLine,
                Text(
                    "values are very close to 1.5 × ULN or 3 × ULN to handle floating-point precision",
                ),
                NewLine,
                Text(
                    "issues that can occur with calculated thresholds.",
                ),
                NewLine,
            ],
        },
