                    ),
                    NewLine,
                    Text(
                        "  ULNAST = 33,",
                    ),
                    NewLine,
                    Text(
                        "  BILI = c(0.8, 1.0, 2.2, 4.5, 1.8, 0.9),",
                    ),
                    NewLine,
                    Text(
                        "  ULNBILI = 1.2",
                    ),
                    NewLine,
                    Text(
